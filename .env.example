# API-ключ DeepSeek (обязательно)
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# MCP_USE_WORKER=true — включает SwarmWorker с кэшем, rate limiter, авто-выбор модели
MCP_USE_WORKER=true

# Модели не заданы — ModelSelector сам выберет deepseek-chat или deepseek-reasoner
# в зависимости от сложности задачи (low/medium/high/critical)
#ARCHITECT_MODEL=deepseek-chat
#CODER_MODEL=deepseek-chat
#REVIEWER_MODEL=deepseek-chat

# Базовый URL API DeepSeek
BASE_URL=https://api.deepseek.com/v1

# Температура модели (низкая для предсказуемости)
TEMPERATURE=0.1

# Максимальное количество итераций кодер->ревьюер
MAX_ITERATIONS=3

# OpenTelemetry
# OTLP gRPC endpoint для экспорта трейсов (Jaeger, SigNoz, Grafana Tempo и др.)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# Окружение для трассировки (development, staging, production)
OTEL_ENVIRONMENT=development
# Имя сервиса для трассировки
OTEL_SERVICE_NAME=swarm
